<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:TemplateControl">

    <Styles.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/Themes/NumericPadTheme.axaml" />
                <ResourceInclude Source="/Themes/SetValueControlTheme.axaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- PipeControl ControlTheme -->
            <ControlTheme x:Key="{x:Type local:PipeControl}" TargetType="local:PipeControl">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Template">
                    <ControlTemplate>
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" />
                    </ControlTemplate>
                </Setter>
            </ControlTheme>
        </ResourceDictionary>
    </Styles.Resources>
</Styles>
