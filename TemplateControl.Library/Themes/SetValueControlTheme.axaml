<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="using:TemplateControl"
                    xmlns:conv="using:TemplateControl.Library.Converters"
                    xmlns:sys="using:System">

    <conv:SafeZoneColorConverter x:Key="SafeZoneColor" />

    <SolidColorBrush x:Key="SetValueSafeMinLabelBrush" Color="#4488FF" />
    <SolidColorBrush x:Key="SetValueSafeMaxLabelBrush" Color="#00FF66" />
    <SolidColorBrush x:Key="SetValueApplyBtnBgBrush" Color="#3300FF66" />
    <SolidColorBrush x:Key="SetValueApplyBtnBorderBrush" Color="#00FF66" />
    <SolidColorBrush x:Key="SetValueRecommendedBtnBgBrush" Color="#1A00FF66" />
    <SolidColorBrush x:Key="SetValueRecommendedBtnBorderBrush" Color="#00FF66" />
    <SolidColorBrush x:Key="SetValueRecommendedTextBrush" Color="#00FF66" />
    <SolidColorBrush x:Key="SetValueOverlayBgBrush" Color="#E61E1E22" />
    <SolidColorBrush x:Key="SetValueWarningTextBrush" Color="#FFD700" />
    <SolidColorBrush x:Key="SetValueConfirmBtnBgBrush" Color="#B2FFD700" />

    <SolidColorBrush x:Key="SetValueControlBgBrush" Color="#0CFFFFFF" />
    <SolidColorBrush x:Key="SetValueControlBorderBrush" Color="#26FFFFFF" />
    
    <SolidColorBrush x:Key="SetValueInternalFrameBgBrush" Color="#1AFFFFFF" />
    <SolidColorBrush x:Key="SetValueInternalFrameBorderBrush" Color="#40FFFFFF" />

    <ControlTheme x:Key="{x:Type local:SetValueControl}" TargetType="local:SetValueControl">
        
        <Setter Property="Background" Value="{DynamicResource SetValueControlBgBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SetValueControlBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="MinHeight" Value="150" />

        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}">
                    
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*">
                        
                        <!-- Title Header -->
                        <TextBlock Grid.Row="0" Text="{TemplateBinding Title}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" LetterSpacing="2" Margin="0,0,0,12" IsVisible="{Binding Title, RelativeSource={RelativeSource TemplatedParent}, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                        <!-- Values & Numpad Toggle -->
                        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
                            <StackPanel Grid.Column="0" Orientation="Vertical">
                                <!-- Уставка Label with Blue Outline -->
                                <Border BorderBrush="#4488FF" BorderThickness="1" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" Margin="0,0,0,6">
                                    <TextBlock Text="УСТАВКА" FontSize="10" FontWeight="Bold" Foreground="#4488FF" LetterSpacing="1.5" />
                                </Border>
                                
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom">
                                    <TextBlock Text="{Binding #PART_Track.Value, StringFormat={}{0:F2}}" FontSize="32" FontWeight="Bold" x:Name="TargetValueDisplay">
                                        <TextBlock.Foreground>
                                            <MultiBinding Converter="{StaticResource SafeZoneColor}">
                                                <Binding Path="#PART_Track.Value" />
                                                <Binding Path="SafeMinimum" RelativeSource="{RelativeSource TemplatedParent}" />
                                                <Binding Path="SafeMaximum" RelativeSource="{RelativeSource TemplatedParent}" />
                                                <Binding Path="SafeZonesEnabled" RelativeSource="{RelativeSource TemplatedParent}" />
                                            </MultiBinding>
                                        </TextBlock.Foreground>
                                    </TextBlock>
                                    
                                    <!-- Тек: Label with Blue Outline and Value -->
                                    <StackPanel x:Name="PART_CurrentValueDisplay" Orientation="Horizontal" Spacing="6" VerticalAlignment="Bottom" Margin="0,0,0,6">
                                        <Border BorderBrush="#4488FF" BorderThickness="1" CornerRadius="4" Padding="4,2" VerticalAlignment="Center">
                                            <TextBlock Text="Тек:" FontSize="10" FontWeight="Bold" Foreground="#4488FF" />
                                        </Border>
                                        <TextBlock Text="{Binding CurrentValue, RelativeSource={RelativeSource TemplatedParent}, StringFormat={}{0:F2}}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorTertiaryBrush}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <Button Grid.Column="1" x:Name="PART_NumPadToggle" Width="40" Height="40" VerticalAlignment="Top" AutomationProperties.Name="Open Numeric Pad">
                                <TextBlock Text="🔢" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Button>
                        </Grid>

                        <!-- Slider and Steppers -->
                        <Border Grid.Row="2" x:Name="PART_SliderGrid" 
                                Background="{DynamicResource SetValueInternalFrameBgBrush}"
                                BorderBrush="{DynamicResource SetValueInternalFrameBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="16,12"
                                Margin="0,0,0,16">
                            <Grid RowDefinitions="Auto,Auto">
                                
                                <!-- Safe Bounds Labels -->
                                <Grid Grid.Row="0" Margin="44,0,92,0" IsVisible="{TemplateBinding SafeZonesEnabled}">
                                    <TextBlock HorizontalAlignment="Left" Text="{Binding SafeMinimum, RelativeSource={RelativeSource TemplatedParent}, StringFormat={}Безоп. мин: {0:F1}}" FontSize="10" Foreground="{DynamicResource SetValueSafeMinLabelBrush}" Opacity="0.8" />
                                    <TextBlock HorizontalAlignment="Right" Text="{Binding SafeMaximum, RelativeSource={RelativeSource TemplatedParent}, StringFormat={}Безоп. макс: {0:F1}}" FontSize="10" Foreground="{DynamicResource SetValueSafeMaxLabelBrush}" Opacity="0.8" />
                                </Grid>
                                
                                <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,4,0,0">
                                    <Button Grid.Column="0" x:Name="PART_DecreaseBtn" Content="-" Width="40" Height="40" FontSize="20" FontWeight="Bold" AutomationProperties.Name="Decrease Value" />
                                    
                                    <Slider Grid.Column="1" x:Name="PART_Track" 
                                            Margin="16,0" VerticalAlignment="Center"
                                            Minimum="{TemplateBinding Minimum}" 
                                            Maximum="{TemplateBinding Maximum}">
                                            <Slider.Foreground>
                                                <MultiBinding Converter="{StaticResource SafeZoneColor}">
                                                    <Binding Path="#PART_Track.Value" />
                                                    <Binding Path="SafeMinimum" RelativeSource="{RelativeSource TemplatedParent}" />
                                                    <Binding Path="SafeMaximum" RelativeSource="{RelativeSource TemplatedParent}" />
                                                    <Binding Path="SafeZonesEnabled" RelativeSource="{RelativeSource TemplatedParent}" />
                                                </MultiBinding>
                                            </Slider.Foreground>
                                    </Slider>
                                            
                                    <Button Grid.Column="2" x:Name="PART_IncreaseBtn" Content="+" Width="40" Height="40" FontSize="20" FontWeight="Bold" AutomationProperties.Name="Increase Value" />

                                    <Button Grid.Column="3" x:Name="PART_ApplyTrackBtn" 
                                            Content="✔️" Width="40" Height="40" FontSize="16" 
                                            Margin="8,0,0,0" Opacity="0" IsHitTestVisible="False"
                                            Background="{DynamicResource SetValueApplyBtnBgBrush}" 
                                            BorderBrush="{DynamicResource SetValueApplyBtnBorderBrush}" BorderThickness="1"
                                            AutomationProperties.Name="Apply Slider Value">
                                        <Button.Transitions>
                                            <Transitions>
                                                <DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
                                            </Transitions>
                                        </Button.Transitions>
                                    </Button>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Quick Set & Recommendations -->
                        <Grid Grid.Row="3" x:Name="PART_QuickSetGrid" ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                            <!-- Recent values -->
                            <ItemsControl x:Name="PART_QuickSetPanel" ItemsSource="{TemplateBinding RecentValues}" Grid.Column="0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="sys:Decimal">
                                        <Button Content="{Binding StringFormat={}{0:F1}}" 
                                                CommandParameter="{Binding}"
                                                Margin="0,0,8,0"
                                                Padding="12,6"
                                                CornerRadius="16"
                                                FontSize="12"
                                                Background="{DynamicResource ControlFillColorSecondaryBrush}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Recommended Value -->
                            <Button Grid.Column="1" 
                                    x:Name="RecommendedBtn"
                                    IsVisible="{TemplateBinding RecommendedValue, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    CommandParameter="{TemplateBinding RecommendedValue}"
                                    CornerRadius="16"
                                    Padding="12,6"
                                    Background="{DynamicResource SetValueRecommendedBtnBgBrush}"
                                    BorderBrush="{DynamicResource SetValueRecommendedBtnBorderBrush}"
                                    BorderThickness="1"
                                    AutomationProperties.Name="Set Recommended Value">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="💡" FontSize="12" />
                                    <TextBlock Text="{Binding RecommendedValue, RelativeSource={RelativeSource TemplatedParent}, StringFormat={}{0:F1}}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource SetValueRecommendedTextBrush}" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- Confirm Overlay (Hidden by default) -->
                        <Border Grid.Row="0" Grid.RowSpan="3" x:Name="PART_ConfirmOverlay" 
                                Background="{DynamicResource SetValueOverlayBgBrush}" CornerRadius="8" 
                                IsVisible="False" Padding="20">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
                                <TextBlock Text="⚠️ ТРЕБУЕТСЯ ПОДТВЕРЖДЕНИЕ" Foreground="{DynamicResource SetValueWarningTextBrush}" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" />
                                <TextBlock Text="Вы пытаетесь установить небезопасное значение или совершаете большой скачок. Подтвердить?" Foreground="#FFFFFF" TextWrapping="Wrap" MaxWidth="300" TextAlignment="Center" HorizontalAlignment="Center" />
                                <StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Center" Margin="0,8,0,0">
                                    <Button x:Name="PART_CancelBtn" Content="ОТМЕНА" Width="100" HorizontalContentAlignment="Center" />
                                    <Button x:Name="PART_ConfirmBtn" Content="ПРИМЕНИТЬ" Width="100" HorizontalContentAlignment="Center" Background="{DynamicResource SetValueConfirmBtnBgBrush}" Foreground="Black" FontWeight="Bold" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Numeric Pad Popup -->
                        <Popup x:Name="PART_NumPadPopup" 
                               PlacementTarget="PART_NumPadToggle" 
                               Placement="BottomEdgeAlignedRight" 
                               IsLightDismissEnabled="True">
                            <Border Background="{DynamicResource FlyoutPresenterBackground}" 
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" 
                                    BorderThickness="1" CornerRadius="8" Padding="10"
                                    BoxShadow="0 8 16 0 #40000000">
                                <local:NumericPad Minimum="{TemplateBinding Minimum}" 
                                                  Maximum="{TemplateBinding Maximum}" 
                                                  ShowDecimalSeparator="True" />
                            </Border>
                        </Popup>

                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter>

        <!-- PseudoClass states -->
        
        <!-- :numpad-open highlights the toggle button -->
        <Style Selector="^:numpad-open /template/ Button#PART_NumPadToggle">
            <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
        </Style>

        <!-- :warning shows the confirm overlay and adds border glow -->
        <Style Selector="^:warning /template/ Border#PART_ConfirmOverlay">
            <Setter Property="IsVisible" Value="True" />
        </Style>
        <Style Selector="^:warning">
            <Setter Property="BorderBrush" Value="{DynamicResource SetValueWarningTextBrush}" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>

        <!-- :error flashes the target value display red -->
        <Style Selector="^:error /template/ TextBlock#TargetValueDisplay">
            <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}" />
        </Style>
        <Style Selector="^:error">
            <Setter Property="BorderBrush" Value="{DynamicResource SystemFillColorCriticalBrush}" />
        </Style>

        <!-- :auto-precision adds visual cue to track or buttons -->
        <Style Selector="^:auto-precision /template/ Button#PART_DecreaseBtn">
            <Setter Property="Foreground" Value="{DynamicResource AccentFillColorDefaultBrush}" />
        </Style>
        <Style Selector="^:auto-precision /template/ Button#PART_IncreaseBtn">
            <Setter Property="Foreground" Value="{DynamicResource AccentFillColorDefaultBrush}" />
        </Style>

        <!-- :track-dirty shows the apply button -->
        <Style Selector="^:track-dirty /template/ Button#PART_ApplyTrackBtn">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="IsHitTestVisible" Value="True" />
        </Style>

        <!-- :mode-minimal hides the slider and quick sets -->
        <Style Selector="^:mode-minimal /template/ Border#PART_SliderGrid">
            <Setter Property="IsVisible" Value="False" />
        </Style>
        <Style Selector="^:mode-minimal /template/ Grid#PART_QuickSetGrid">
            <Setter Property="IsVisible" Value="False" />
        </Style>
        <Style Selector="^:mode-minimal /template/ StackPanel#PART_CurrentValueDisplay">
            <Setter Property="IsVisible" Value="False" />
        </Style>
        <Style Selector="^:mode-minimal">
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Padding" Value="16,16,16,0" />
        </Style>

    </ControlTheme>

</ResourceDictionary>
