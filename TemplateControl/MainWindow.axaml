<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hmi="using:TemplateControl"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
        Width="1200" Height="700"
        x:Class="TemplateControl.Demo.MainWindow"
        Title="HMI Industrial Controls - Library Demonstration"
        Background="#121214">

    <Grid RowDefinitions="Auto,*">
        <!-- Header Panel -->
        <Border Grid.Row="0" Background="#1E1E22" BorderBrush="#2D2D34" BorderThickness="0,0,0,1" Padding="20,15">
            <StackPanel Orientation="Horizontal" Spacing="15" VerticalAlignment="Center">
                <!-- Mini LED indicator -->
                <Ellipse Width="12" Height="12" Fill="#00FF66" Margin="0,2,0,0">
                    <Ellipse.Transitions>
                        <Transitions>
                            <DoubleTransition Property="Opacity" Duration="0:0:0.5" />
                        </Transitions>
                    </Ellipse.Transitions>
                </Ellipse>
                <TextBlock Text="INDUSTRIAL HMI SYSTEM" Foreground="#A9A9B2" FontSize="12" FontWeight="SemiBold" LetterSpacing="1.5" VerticalAlignment="Center"/>
                <TextBlock Text="|" Foreground="#3E3E42" FontSize="14" VerticalAlignment="Center"/>
                <TextBlock Text="CONTROL LIBRARY DEMONSTRATION" Foreground="#FFFFFF" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Main Workspace: Tabs -->
        <TabControl Grid.Row="1" Background="#0F0F11" Margin="0">
            <TabControl.Styles>
                <Style Selector="TabItem">
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="MinHeight" Value="48"/>
                </Style>
            </TabControl.Styles>

            <!-- TAB 1: PIPES -->
            <TabItem Header="PipeControl">
                <Grid ColumnDefinitions="280,*">
                    <!-- Controls / Properties Panel (Left) -->
                    <Border Grid.Column="0" Background="#18181C" BorderBrush="#2D2D34" BorderThickness="0,0,1,0" Padding="20">
                        <ScrollViewer>
                            <StackPanel Spacing="20">
                                <TextBlock Text="PipeControl" Foreground="#FFFFFF" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
                                
                                <Border Background="#222228" CornerRadius="6" Padding="12" BorderBrush="#2D2D34" BorderThickness="1">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="3D Volume Shading" Foreground="#E1E1E6" FontWeight="SemiBold" FontSize="13"/>
                                        <TextBlock Text="Pipe segments are rendered with dynamic multi-stop linear gradients to simulate cylindrical volume." Foreground="#A9A9B2" FontSize="11" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <Border Background="#222228" CornerRadius="6" Padding="12" BorderBrush="#2D2D34" BorderThickness="1">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Elbows &amp; Fittings" Foreground="#E1E1E6" FontWeight="SemiBold" FontSize="13"/>
                                        <TextBlock Text="Supports 90° and 45° elbows, flanges, and automatic corner rounding at intermediate coordinates." Foreground="#A9A9B2" FontSize="11" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <Border Background="#222228" CornerRadius="6" Padding="12" BorderBrush="#2D2D34" BorderThickness="1">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Interactive Design Mode" Foreground="#E1E1E6" FontWeight="SemiBold" FontSize="13"/>
                                        <TextBlock Text="Enable design mode to show joint coordinates and interact with the pipeline routing via mouse context menus." Foreground="#A9A9B2" FontSize="11" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <!-- Showcase (Right) -->
                    <Canvas Grid.Column="1" Margin="40">
                        <!-- Grid Reference Visuals -->
                        <TextBlock Canvas.Left="0" Canvas.Top="-25" Text="SCADA MIMIC PANEL (CELL SIZE = 30px)" Foreground="#5E5E66" FontSize="11" FontWeight="Bold"/>

                        <!-- Pipeline 1: Water Blue Pipe (Active flow, Thickness 16, Flanges) -->
                        <hmi:PipeControl Points="1,2;5,2;5,5;11,5" 
                                         CellSize="30" 
                                         Thickness="16" 
                                         IsFilled="True"
                                         ActiveColor="#00A2FF"
                                         StartFitting="Flange"
                                         EndFitting="Flange" />

                        <!-- Labels for Pipeline 1 -->
                        <TextBlock Canvas.Left="45" Canvas.Top="40" Text="Pipeline A: Cooling Water Flow (Active)" Foreground="#00A2FF" FontSize="11" FontWeight="SemiBold"/>
                        <TextBlock Canvas.Left="345" Canvas.Top="168" Text="Flange" Foreground="#8A8A93" FontSize="10"/>
                        <TextBlock Canvas.Left="15" Canvas.Top="78" Text="Flange" Foreground="#8A8A93" FontSize="10"/>

                        <!-- Pipeline 2: Steam Red Pipe (Inactive, Thickness 22, Elbows) -->
                        <hmi:PipeControl Points="1,7;7,7;7,11;14,11" 
                                         CellSize="30" 
                                         Thickness="22" 
                                         IsFilled="False"
                                         InactiveColor="#8A2E2E"
                                         StartFitting="Elbow90"
                                         EndFitting="ElbowMinus90" />
                        
                        <!-- Labels for Pipeline 2 -->
                        <TextBlock Canvas.Left="45" Canvas.Top="190" Text="Pipeline B: Steam Pressure (Inactive / Empty)" Foreground="#EC5B5B" FontSize="11" FontWeight="SemiBold"/>
                        <TextBlock Canvas.Left="10" Canvas.Top="250" Text="90° Elbow" Foreground="#8A8A93" FontSize="10"/>
                        <TextBlock Canvas.Left="430" Canvas.Top="350" Text="-90° Elbow" Foreground="#8A8A93" FontSize="10"/>

                        <!-- Pipeline 3: Gas Green Pipe (Active, Thickness 12, Design Mode) -->
                        <hmi:PipeControl Points="3,13;10,13;13,10;19,10" 
                                         CellSize="30" 
                                         Thickness="12" 
                                         IsFilled="True"
                                         ActiveColor="#00E676"
                                         StartFitting="None"
                                         EndFitting="Flange"
                                         IsDesignMode="True" />
                        
                        <!-- Labels for Pipeline 3 -->
                        <TextBlock Canvas.Left="100" Canvas.Top="375" Text="Pipeline C: Natural Gas (Active - Design Mode Markers Visible)" Foreground="#00E676" FontSize="11" FontWeight="SemiBold"/>
                        <TextBlock Canvas.Left="330" Canvas.Top="320" Text="45° Angle Snapping" Foreground="#8A8A93" FontSize="10"/>
                    </Canvas>
                </Grid>
            </TabItem>

            <!-- TAB 2: NUMERIC PAD -->
            <TabItem Header="NumericPad">
                <Grid ColumnDefinitions="280,*">
                    <!-- Panel (Left) -->
                    <Border Grid.Column="0" Background="#18181C" BorderBrush="#2D2D34" BorderThickness="0,0,1,0" Padding="20">
                        <StackPanel Spacing="20">
                            <TextBlock Text="NumericPad" Foreground="#FFFFFF" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>

                            <Border Background="#222228" CornerRadius="6" Padding="12" BorderBrush="#2D2D34" BorderThickness="1">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Touch Numeric Input" Foreground="#E1E1E6" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="Virtual keypad for terminal/POS input. Supports value validation, decimal separator, min/max bounds with visual error feedback." Foreground="#A9A9B2" FontSize="11" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                    <!-- Content -->
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">
                        <hmi:NumericPad Minimum="0"
                                        Maximum="999.99"
                                        MaxLength="6"
                                        ShowDecimalSeparator="True"
                                        HorizontalAlignment="Center" />
                        <TextBlock Text="Range: 0 — 999.99" 
                                   Foreground="#8A8A93" 
                                   FontSize="12" 
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- TAB 3: SET VALUE CONTROL -->
            <TabItem Header="SetValueControl">
                <Grid ColumnDefinitions="280,*">
                    <!-- Panel (Left) -->
                    <Border Grid.Column="0" Background="#18181C" BorderBrush="#2D2D34" BorderThickness="0,0,1,0" Padding="20">
                        <StackPanel Spacing="20">
                            <TextBlock Text="SetValueControl" Foreground="#FFFFFF" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>

                            <Border Background="#222228" CornerRadius="6" Padding="12" BorderBrush="#2D2D34" BorderThickness="1">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Smart Setpoint Input" Foreground="#E1E1E6" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="Universal controller featuring numeric pad integration via popup, adaptive precision, bounds checking, and safe zones." Foreground="#A9A9B2" FontSize="11" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#222228" CornerRadius="6" Padding="12" BorderBrush="#2D2D34" BorderThickness="1">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="ML Recommendations" Foreground="#E1E1E6" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="Allows feeding external AI/ML suggestions safely to operators without executing logic itself." Foreground="#A9A9B2" FontSize="11" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#222228" CornerRadius="6" Padding="12" BorderBrush="#2D2D34" BorderThickness="1">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Critical Actions" Foreground="#E1E1E6" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="Changing value drastically (>20%) or entering a dangerous limit triggers an explicit overlay confirmation." Foreground="#A9A9B2" FontSize="11" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                    <!-- Content -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="24">

                        <hmi:SetValueControl x:Name="DemoSetValueControl" 
                                             Title="TANK #4 TEMPERATURE SETPOINT (FULL MODE)"
                                             Width="500"
                                             Minimum="0" Maximum="200" 
                                             SafeMinimum="20" SafeMaximum="150" 
                                             Value="72.5" CurrentValue="72.5"
                                             RecommendedValue="77.3"
                                             AdaptiveStepEnabled="True"
                                             ValueChanged="OnSetValueChanged"
                                             CriticalChangeRequested="OnCriticalChangeRequested" />

                        <hmi:SetValueControl x:Name="MinimalSetValueControl" 
                                             Title="TANK #5 PRESSURE SETPOINT (MINIMAL MODE)"
                                             Width="300"
                                             DisplayMode="Minimal"
                                             Minimum="0" Maximum="100" 
                                             SafeMinimum="10" SafeMaximum="90" 
                                             Value="45.0" CurrentValue="45.0"
                                             ValueChanged="OnSetValueChanged"
                                             CriticalChangeRequested="OnCriticalChangeRequested" />

                        <Border Background="#1A000000" CornerRadius="8" Padding="16" Width="500">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Demo Output Log:" Foreground="#5E5E66" FontSize="11" FontWeight="Bold" />
                                <ScrollViewer MaxHeight="100">
                                    <TextBlock x:Name="DemoLog" Foreground="#00FF66" FontSize="12" FontFamily="Consolas" TextWrapping="Wrap" />
                                </ScrollViewer>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
